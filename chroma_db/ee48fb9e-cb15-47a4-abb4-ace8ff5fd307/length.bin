invalid type: string "})\r\n     return num\r\n }\r\n```\r\n\r\n122.买卖股票最佳时机\r\n\r\n```javascript\r\nfunction maxProfit(prices) {\r\n    let num = 0;\r\n    for(let i=1; i<prices.length; i++) {\r\n     \tif (prices[i] > prices[i-1]) {\r\n            num+= prices[i] - prices[i-1]\r\n        }\r\n    }\r\n    return num;\r\n}\r\n\r\nmaxProfit([7,1,5,3,6,4])\r\n```\r\n\r\n\r\n\r\n\r\n